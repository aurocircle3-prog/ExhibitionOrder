# Server
PORT=3000
JWT_SECRET=change-me-in-production
APP_URL=http://localhost:3000

# MongoDB (leave blank to use local db/db.json for dev)
MONGO_URI=

# Cloudflare R2 (leave any blank to fall back to local disk storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Optional OCR for visiting-card autofill (Google Cloud Vision API key).
# Leave blank to skip OCR — staff will type firm/contact name manually.
OCR_API_KEY=
